# lxpanel <profile> config file. Manually editing is not recommended.
# Use preference dialog in lxpanel to adjust config when you can.

Global {
  edge=top
  allign=left
  margin=3
  widthtype=percent
  width=44
  height=26
  transparent=1
  tintcolor=#040404
  alpha=0
  setdocktype=1
  setpartialstrut=0
  usefontcolor=0
  fontcolor=#9141ac
  usefontsize=1
  fontsize=11
  background=0
  backgroundfile=/home/$USER/.config/lxpanel/panel2.png
  align=center
  monitor=0
  iconsize=23
  autohide=1
  heightwhenhidden=1
}
Plugin {
  type=tray
  Config {
  }
}
Plugin {
  type=volume
  Config {
  }
}
Plugin {
  type=space
  Config {
  }
  expand=1
}
Plugin {
  type=dclock
  Config {
    ClockFmt=%H:%M
    TooltipFmt=%A, All Day
    BoldFont=0
    IconOnly=0
    CenterText=0
    Action=gsimplecal
  }
}
Plugin {
  type=weather
  Config {
    units=f
    interval=30
    enabled=1
    provider=openweathermap
    alias=""
    city=""
    state=
    country=
    latitude=
    longitude=
  }
}
Plugin {
  type=batt
  Config {
    BackgroundColor=black
    ChargingColor1=#28f200
    ChargingColor2=#22cc00
    DischargingColor1=#ffee00
    DischargingColor2=#d9ca00
    HideIfNoBattery=1
    AlarmCommand=notify-send "Battery low" --icon=battery-caution
    AlarmTime=6
    BorderWidth=1
    Size=8
    ShowExtendedInformation=1
    BatteryNumber=0
    BatteryNumberHide=1
  }
}
